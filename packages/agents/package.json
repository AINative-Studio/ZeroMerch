{
  "name": "@zeromerch/agents",
  "version": "0.1.0",
  "private": true,
  "description": "AI agent package for ZeroMerch — MerchConciergeAgent with Claude tool use, ZeroDB memory, and streaming",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
