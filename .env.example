# ---------------------------------------------------------------------------
# ZeroMerch — Required Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to .env.local and fill in your values.
# Never commit real secrets.

# AINative Auth
NEXT_PUBLIC_AINATIVE_AUTH_URL=
AINATIVE_AUTH_SECRET=
AINATIVE_CLIENT_ID=
AINATIVE_CLIENT_SECRET=

# ZeroDB
ZERODB_PROJECT_ID=
ZERODB_API_KEY=
NEXT_PUBLIC_ZERODB_PROJECT_ID=

# ZeroCommerce API
ZEROCOMMERCE_API_URL=
ZEROCOMMERCE_API_KEY=

# App
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_APP_ENV=development

# Stripe (for checkout — wired in Batch C)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
